        let chatOpen = false;
        function toggleBot() { chatOpen = !chatOpen; document.getElementById('bot-chat-window').style.display = chatOpen ? 'flex' : 'none'; if(chatOpen) { document.getElementById('bot-search-container').style.display = 'block'; if(document.getElementById('bot-messages').innerHTML.trim() === '') initKonectinho(); } }
        function appendBotMessageHTML(htmlContent, isUser = false) { const container = document.getElementById('bot-messages'); const msgDiv = document.createElement('div'); msgDiv.className = `msg ${isUser ? 'msg-user' : 'msg-bot'}`; msgDiv.innerHTML = htmlContent; container.appendChild(msgDiv); container.scrollTop = container.scrollHeight; }
        function copiarTextoBot(texto) { navigator.clipboard.writeText(texto).then(() => { showToast("📋 Frase copiada!"); }); }

        function initKonectinho() { document.getElementById('bot-messages').innerHTML = ''; document.getElementById('bot-search').value = ''; appendBotMessageHTML("Olá! Sou o <b>KONECTINHO</b> 🤖, seu parceiro de fechamentos!<br>Pesquise acima ou escolha uma opção:"); mostrarMenuPrincipal(); }

        function mostrarMenuPrincipal() {
            let menuHTML = `<div class="bot-menu-grid" id="menu-categorias-bot">`;
            for (let chave in konectinhoDB) { menuHTML += `<button class="bot-menu-btn" onclick="carregarObjecao('${chave}')">${konectinhoDB[chave].titulo}</button>`; }
            menuHTML += `</div>`; appendBotMessageHTML(menuHTML, false);
        }

        function filtrarMenuBot() {
            const termo = document.getElementById('bot-search').value.toLowerCase();
            const container = document.getElementById('menu-categorias-bot'); if(!container) return; 
            let html = '', achouAlgo = false;
            for (let chave in konectinhoDB) {
                const d = konectinhoDB[chave];
                if(d.titulo.toLowerCase().includes(termo) || d.palavras.join(" ").includes(termo)) { html += `<button class="bot-menu-btn" onclick="carregarObjecao('${chave}')">${d.titulo}</button>`; achouAlgo = true; }
            }
            if(!achouAlgo && termo !== "") html += `<div style="font-size:12px; color:var(--danger); width:100%; text-align:center;">Nada encontrado.</div>`;
            container.innerHTML = html;
        }

        function carregarObjecao(chave) {
            const dados = konectinhoDB[chave]; document.getElementById('bot-search-container').style.display = 'none'; 
            appendBotMessageHTML(`Ajuda com: ${dados.titulo}`, true);
            setTimeout(() => {
                let respHTML = `<div style="font-weight:bold; border-bottom: 1px solid var(--border-color); padding-bottom:5px; margin-bottom:5px;">🎯 ${dados.titulo}</div><div class="bot-tip-box"><span>💡 Dica:</span> ${dados.dica}</div><ul class="bot-list">`;
                dados.respostas.forEach(r => { respHTML += `<li class="bot-list-item"><span style="flex:1;">${r}</span><button class="copy-btn" onclick="copiarTextoBot('${r.replace(/'/g, "\\'")}')">📋</button></li>`; });
                respHTML += `</ul>
                <button class="bot-menu-btn" style="background:var(--warning); color:black; font-weight:bold; width:100%; margin-top:10px;" onclick="mostrarContrapropostaBot('${chave}')">❌ Cliente Recusou? (Contraproposta)</button>
                <button class="bot-menu-btn bot-menu-btn-voltar" onclick="document.getElementById('bot-search-container').style.display='block'; initKonectinho()">🔄 Voltar ao Início</button>`;
                appendBotMessageHTML(respHTML, false);
            }, 400);
        }

        function mostrarContrapropostaBot(chave) {
            const dados = konectinhoDB[chave];
            appendBotMessageHTML(`O cliente recusou.`, true);
            setTimeout(() => {
                let html = `<div style="font-weight:bold; margin-bottom:10px;">Como ele reagiu agora?</div><div class="bot-menu-grid">`;
                dados.reacoes.forEach((r, idx) => { html += `<button class="bot-menu-btn" style="background:var(--navy);" onclick="darRespostaContraproposta('${chave}', ${idx})">${r.cenario}</button>`; });
                html += `</div><button class="bot-menu-btn bot-menu-btn-voltar" onclick="carregarObjecao('${chave}')">🔄 Voltar para Respostas Iniciais</button>`;
                appendBotMessageHTML(html, false);
            }, 400);
        }

        function darRespostaContraproposta(chave, index) {
            const r = konectinhoDB[chave].reacoes[index];
            appendBotMessageHTML(r.cenario, true);
            setTimeout(() => {
                let html = `<div style="background:#FFFBEB; border-left:4px solid var(--warning); padding:10px; font-size:13px; color:#92400E;"><b>💡 Sugestão Final:</b><br><br>${r.resposta}</div>
                <button class="bot-menu-btn" style="background:var(--warning); color:black; font-weight:bold; width:100%; margin-top:8px;" onclick="copiarTextoBot('${r.resposta.replace(/'/g, "\\'")}')">📋 Copiar Resposta</button>`;
                appendBotMessageHTML(html, false);
            }, 400);
        }
    </script>
